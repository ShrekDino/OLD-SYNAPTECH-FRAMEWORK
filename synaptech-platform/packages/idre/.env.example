# SynapTech IDRE — Environment Configuration
# Copy to .env and fill in values

# ── GPU / CSC ──────────────────────────────────────────────────────────
CSC_DTYPE=float32
N_NEURONS=130000

# ── Data Paths ─────────────────────────────────────────────────────────
DATA_PATH=/data/flywire
LAYOUT_PATH=/data/layout.json

# ── Authentication ─────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-random-secret
API_KEYS=dev-key-1,dev-key-2

# ── Pinecone (Vector DB for telemetry) ─────────────────────────────────
PINECONE_API_KEY=
PINECONE_INDEX=synaptech-telemetry

# ── DeepSeek (1M-context alignment) ────────────────────────────────────
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4

# ── Lava / Loihi (Neuromorphic) ────────────────────────────────────────
LAVA_BACKEND=sim           # "sim" for CPU, "loihi2" for hardware
INRC_ENABLED=false          # Set true if INRC member with Loihi access

# ── S3 / MinIO (Encrypted IP storage) ──────────────────────────────────
S3_ENDPOINT=http://minio:9000
S3_BUCKET=synaptech-ip-encrypted
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin

# ── Logging ────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
