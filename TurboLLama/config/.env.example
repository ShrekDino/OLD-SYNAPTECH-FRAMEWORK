# TurboLLama environment defaults
# Copy to: /etc/systemd/system/ollama.service.d/turboquant.conf

# KV cache type: turbo3 (~3.5 bpv, 4.6x compression) or turbo4 (~4.25 bpv, 3.8x)
OLLAMA_KV_CACHE_TYPE=turbo3

# Set to 1 for flash attention (may require TBQ CUDA template compilation)
OLLAMA_FLASH_ATTENTION=0

# MoE expert cache size in MB (0 = disabled)
OLLAMA_EXPERT_CACHE_SIZE=1024

# Model storage directory
OLLAMA_MODELS=$HOME/.ollama/models

# Context length (0 = auto-detect)
OLLAMA_CONTEXT_LENGTH=0
