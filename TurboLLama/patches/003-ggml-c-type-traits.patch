+// Simple hint marker for Hadamard-wrapped MUL_MAT (scheduler optimization)
+#define GGML_HINT_SRC0_IS_HADAMARD 1
+static void ggml_mul_mat_set_hint(struct ggml_tensor * a, int32_t hint) {
+    GGML_ASSERT(a->op == GGML_OP_MUL_MAT);
+    ggml_set_op_params_i32(a, 1, hint);
+}
