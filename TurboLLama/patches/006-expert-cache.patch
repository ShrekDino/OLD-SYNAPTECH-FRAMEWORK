 #include <string>
 #include <vector>
 
+// Expert cache: LRU for MoE expert weights
+struct expert_cache_ent { uint64_t key; void * dev_ptr; size_t n_bytes; };
+static struct expert_cache_ent g_ecache[256];
+static int g_ecache_n = 0;
+static int64_t g_ecache_used = 0;
+static int64_t g_ecache_max = 1073741824;
+
+static uint64_t eckey(const void * t, int e) {
+    return (uint64_t)(uintptr_t)t ^ ((uint64_t)e << 32);
+}
+static void * ecget(uint64_t k) {
+    for (int i = 0; i < g_ecache_n; i++)
+        if (g_ecache[i].key == k) {
+            if (i > 0) { struct expert_cache_ent tmp = g_ecache[i];
+                memmove(&g_ecache[1], &g_ecache[0], i * sizeof(struct expert_cache_ent));
+                g_ecache[0] = tmp; }
+            return g_ecache[0].dev_ptr; }
+    return NULL;
+}
+static void ecput(uint64_t k, void * p, size_t n) {
+    while (g_ecache_n > 0 && g_ecache_used + (int64_t)n > g_ecache_max) {
+        g_ecache_n--; cudaFree(g_ecache[g_ecache_n].dev_ptr);
+        g_ecache_used -= (int64_t)g_ecache[g_ecache_n].n_bytes; }
+    if (g_ecache_n >= 256) { g_ecache_n--; cudaFree(g_ecache[g_ecache_n].dev_ptr); }
+    memmove(&g_ecache[1], &g_ecache[0], g_ecache_n * sizeof(struct expert_cache_ent));
+    g_ecache[0].key = k; g_ecache[0].dev_ptr = p; g_ecache[0].n_bytes = n;
+    g_ecache_n++; g_ecache_used += (int64_t)n;
+}
+
